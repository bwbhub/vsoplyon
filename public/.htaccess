# -----------------------------------------------------------
# .htaccess - a la racine de /www/ sur OVH
# -----------------------------------------------------------

# Force HTTPS
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# SPA fallback : toute route inexistante -> index.html
# (sauf /api/ qui doit etre servi par PHP normalement)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Ne pas intercepter les requetes vers /api/
  RewriteCond %{REQUEST_URI} ^/api/ [OR]
  RewriteCond %{REQUEST_URI} ^/api$
  RewriteRule ^ - [L]

  # Si le fichier ou dossier existe, on le sert
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Sinon, fallback sur index.html (React Router)
  RewriteRule ^ index.html [L]
</IfModule>

# Cache long pour les assets versionnes de Vite (hash dans le nom)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  # index.html doit rester frais
  ExpiresByType text/html                 "access plus 0 seconds"
</IfModule>

# Securite : pas d'indexation
Options -Indexes

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
